---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const downloads = [
  { name: 'Brand Voice Checklist', desc: '10 questions to define how your brand sounds — from tone and vocabulary to personality and what you\'d never say. The fastest way to audit your voice.', tag: 'Voice & Identity', pages: '2 pages' },
  { name: 'Editorial Calendar Template', desc: 'Plan 3 months of content in one afternoon. Includes topic columns, SEO keyword slots, publish dates, status tracking, and platform assignments.', tag: 'Strategy', pages: 'Notion template' },
  { name: 'The Brief Builder', desc: 'A one-page brief that gets writers to nail your voice on the first draft. Share it before every content project and watch revision rounds drop.', tag: 'Process', pages: '1 page' },
  { name: 'SEO Blog Outline Guide', desc: 'Structure any blog post for Google and humans, simultaneously. Includes H-tag hierarchy, intro formula, body structure, and a CTA placement guide.', tag: 'SEO & Structure', pages: '3 pages' },
];
---
<BaseLayout title="Free Downloads — E. Trenchburg Writes" description="Free brand writing tools: Brand Voice Checklist, Editorial Calendar Template, The Brief Builder, and SEO Blog Outline Guide.">
  <Nav />

  <section style="padding-top:calc(var(--nav-h) + 80px);padding-bottom:40px;">
    <div class="container">
      <div class="fade-in" style="max-width:580px;">
        <span class="label" style="margin-bottom:14px;display:block;">On the house</span>
        <h1 class="display-sm" style="font-style:italic;margin-bottom:16px;">Free Downloads</h1>
        <p style="color:var(--text-muted);font-size:1rem;line-height:1.8;">Tools to help your brand write better — on the house. No strings, no hidden upsell. Just genuinely useful resources.</p>
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <div style="display:flex;flex-direction:column;gap:24px;">
        {downloads.map((dl, i) => (
          <div class={`download-card fade-in fade-in-delay-${i % 3 + 1}`}>
            <div class="mockup">
              <img src="/images/product-mockup.jpg" alt={dl.name} style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div>
              <div style="display:flex;gap:10px;align-items:center;margin-bottom:10px;">
                <span class="tag">{dl.tag}</span>
                <span class="label">{dl.pages}</span>
              </div>
              <h2 style="font-family:var(--font-serif);font-size:1.2rem;font-weight:700;margin-bottom:8px;">{dl.name}</h2>
              <p style="font-size:0.88rem;color:var(--text-muted);line-height:1.7;margin-bottom:20px;">{dl.desc}</p>
              <button class="btn btn-primary" style="font-size:0.62rem;padding:10px 20px;" onclick="document.getElementById('download-form').scrollIntoView({behavior:'smooth'})">
                Download Free
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Email gate -->
  <section id="download-form" class="section" style="background:var(--bg-alt);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
    <div class="container" style="max-width:520px;margin:0 auto;text-align:center;">
      <span class="label" style="margin-bottom:16px;display:block;">Get instant access</span>
      <h2 class="heading" style="font-style:italic;margin-bottom:16px;">Drop your email to get all 4 downloads</h2>
      <p style="color:var(--text-muted);font-size:0.9rem;margin-bottom:32px;">We'll also add you to The Editorial newsletter. Unsubscribe anytime.</p>
      <div class="email-strip" style="max-width:420px;margin:0 auto;">
        <input type="email" placeholder="your@email.com" aria-label="Email address" />
        <button type="submit">Get Downloads</button>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
