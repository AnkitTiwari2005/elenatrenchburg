---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Content Strategy & Blogs — E. Trenchburg Writes" description="A full editorial roadmap — topics, SEO, cadence — plus the monthly execution to match.">
  <Nav />

  <section style="padding-top:calc(var(--nav-h) + 80px);padding-bottom:60px;border-bottom:1px solid var(--border);">
    <div class="container">
      <div style="max-width:640px;" class="fade-in">
        <a href="/services" class="label" style="text-decoration:underline;text-underline-offset:3px;margin-bottom:20px;display:block;">← All Services</a>
        <span class="tag tag-filled" style="margin-bottom:20px;">Strategy</span>
        <h1 class="display-sm" style="font-style:italic;margin:16px 0;">Content Strategy & Blogs</h1>
        <p style="font-size:1.1rem;color:var(--text-muted);line-height:1.8;margin-bottom:8px;">A content strategy is a brand's editorial spine. We build them to last.</p>
        <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);">₹6,000 – ₹15,000 / month</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="gap:80px;align-items:start;">

        <div class="fade-in">
          <h2 style="font-family:var(--font-serif);font-style:italic;font-size:1.5rem;margin-bottom:24px;">Monthly deliverables</h2>
          <ul style="display:flex;flex-direction:column;gap:16px;margin-bottom:40px;">
            {[
              ['Monthly editorial calendar', 'Topics, keywords, publish dates, and platform assignments — mapped for the full month in advance.'],
              ['4–8 blog posts per month', 'Fully researched, SEO-optimised articles written in your brand voice. From draft to publish-ready.'],
              ['SEO keyword mapping', 'Every topic is chosen intentionally — mapped to search intent, competition, and your business goals.'],
              ['Monthly performance report', 'Traffic, rankings, and engagement data reviewed monthly so the strategy keeps improving.'],
            ].map(([title, desc]) => (
              <li style="padding:20px;border:1px solid var(--border);border-radius:var(--radius);">
                <strong style="font-size:0.9rem;display:block;margin-bottom:6px;">{title}</strong>
                <span style="font-size:0.85rem;color:var(--text-muted);line-height:1.7;">{desc}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" class="btn btn-primary">Start a Retainer</a>
        </div>

        <div class="fade-in fade-in-delay-2">
          <div style="background:var(--bg-alt);border-radius:var(--radius-lg);padding:40px;border:1px solid var(--border);margin-bottom:28px;">
            <p class="label" style="margin-bottom:16px;">Best for</p>
            <ul class="sparkle-list">
              <li>Brands who want consistent content without managing it</li>
              <li>Companies building organic traffic as a primary channel</li>
              <li>Founders who need a full editorial team, not a freelancer</li>
              <li>Marketing teams that need writing bandwidth at scale</li>
            </ul>
          </div>
          <div style="padding:32px;border:1px solid var(--border);border-radius:var(--radius-lg);">
            <p class="label" style="margin-bottom:12px;">Average client results</p>
            <div style="display:flex;flex-direction:column;gap:14px;">
              {[
                ['3–6 months', 'to first page rankings on target keywords'],
                ['40–60%', 'average increase in organic traffic within 6 months'],
                ['2x–4x', 'growth in content output vs. doing it in-house'],
              ].map(([stat, desc]) => (
                <div style="display:flex;gap:16px;align-items:baseline;">
                  <span style="font-family:var(--font-serif);font-style:italic;font-size:1.4rem;font-weight:700;color:var(--sage);flex-shrink:0;">{stat}</span>
                  <span style="font-size:0.82rem;color:var(--text-muted);line-height:1.5;">{desc}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background:var(--bg-alt);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
    <div class="container" style="max-width:720px;margin:0 auto;">
      <h2 class="heading" style="font-style:italic;margin-bottom:40px;">Common Questions</h2>
      <div style="display:flex;flex-direction:column;gap:0;" class="fade-in">
        {[
          ['How long until I see results?', 'SEO is a long game. Most clients see measurable traffic growth within 3–6 months. Brand authority builds faster — usually within the first 2 months of consistent publishing.'],
          ['Do I need to provide topics?', 'No — topic research is included. We present a full monthly calendar for your approval before writing begins.'],
          ['Can I cancel anytime?', 'Our retainers are month-to-month after an initial 3-month commitment. We ask for 30 days notice to offboard cleanly.'],
          ['Will the writing sound like me?', 'Yes — always. Your first month includes a voice alignment session so every post sounds like it came from inside your brand.'],
        ].map(([q, a]) => (
          <details style="border-bottom:1px solid var(--border);padding:20px 0;cursor:pointer;">
            <summary style="font-family:var(--font-sans);font-weight:600;font-size:0.95rem;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              {q}
              <span style="font-size:1.2rem;color:var(--text-muted);flex-shrink:0;margin-left:20px;">+</span>
            </summary>
            <p style="font-size:0.88rem;color:var(--text-muted);line-height:1.8;margin-top:14px;">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm" style="text-align:center;">
    <div class="container" style="max-width:520px;margin:0 auto;">
      <h2 style="font-family:var(--font-serif);font-style:italic;font-size:1.6rem;margin-bottom:16px;">Stop posting randomly. Start publishing with purpose.</h2>
      <p style="color:var(--text-muted);font-size:0.9rem;margin-bottom:28px;">Tell us where you are and where you want to go — we'll map the editorial path.</p>
      <a href="/contact" class="btn btn-primary">Get in Touch</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
