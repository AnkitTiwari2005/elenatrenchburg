---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Explore — E. Trenchburg Writes" description="Essays, insights, case studies, and brand writing deep-dives from E. Trenchburg Writes.">
  <Nav />

  <!-- Hero -->
  <section style="padding-top:calc(var(--nav-h) + 80px);padding-bottom:60px;border-bottom:1px solid var(--border);">
    <div class="container">
      <div class="fade-in" style="max-width:640px;">
        <span class="label" style="margin-bottom:14px;display:block;">Explore</span>
        <h1 class="display-sm" style="font-style:italic;margin-bottom:16px;">essays, insights,<br />case studies, and deep-dives.</h1>
        <div style="display:flex;gap:24px;margin-top:32px;flex-wrap:wrap;">
          <a href="#blog-section" class="btn btn-outline" style="font-size:0.62rem;padding:10px 20px;">↓ Blog Posts</a>
          <a href="#newsletter-section" class="btn btn-outline" style="font-size:0.62rem;padding:10px 20px;">↓ The Editorial</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Video / Coming Soon -->
  <section style="padding:80px 0;border-bottom:1px solid var(--border);">
    <div class="container">
      <div class="section-header fade-in" style="margin-bottom:40px;">
        <div>
          <span class="label" style="margin-bottom:10px;display:block;">Video</span>
          <h2 class="heading" style="font-style:italic;">Visual Essays</h2>
        </div>
      </div>
      <div class="coming-soon">
        <div class="pulse-text">something worth watching is coming</div>
        <p style="margin-top:20px;font-family:var(--font-mono);font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);">
          In the meantime — <a href="/newsletter" style="text-decoration:underline;color:inherit;">subscribe to The Editorial</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  <section id="blog-section" class="section">
    <div class="container">
      <div class="section-header fade-in">
        <div>
          <span class="label" style="margin-bottom:10px;display:block;">Writing</span>
          <h2 class="heading" style="font-style:italic;">From the Blog</h2>
        </div>
        <a href="/blog" class="btn btn-outline">All posts</a>
      </div>
      <div class="grid-3 fade-in fade-in-delay-1">
        {[
          { title: "Why Your Brand Sounds Like Everyone Else", cat: "Brand Voice", slug: "brand-sounds-like-everyone-else" },
          { title: "The Anatomy of a Thought Leadership Piece", cat: "Editorial Craft", slug: "anatomy-of-thought-leadership" },
          { title: "Long-Form Is Not Dead — It's Just Being Done Wrong", cat: "Content Strategy", slug: "long-form-is-not-dead" },
        ].map(p => (
          <article class="blog-card">
            <div class="card-img" style="aspect-ratio:3/2;border-radius:var(--radius-lg);overflow:hidden;background:var(--bg-alt);">
              <img src="/images/blog-hero-1.jpg" alt={p.title} style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div class="card-body">
              <div class="card-meta"><span class="tag">{p.cat}</span></div>
              <h3><a href={`/blog/${p.slug}`}>{p.title}</a></h3>
              <a href={`/blog/${p.slug}`} class="read-more">Read More →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section id="newsletter-section" class="section" style="background:var(--bg-dark);text-align:center;">
    <div class="container" style="max-width:580px;margin:0 auto;">
      <div class="newsletter-badge" style="border-color:rgba(250,248,245,0.2);color:rgba(250,248,245,0.7);margin:0 auto 28px;">
        <span>✦</span><span>The Editorial</span><span>✦</span>
      </div>
      <h2 style="font-family:var(--font-serif);font-style:italic;font-size:2rem;color:var(--bg);margin-bottom:16px;">Sharp writing, weekly.</h2>
      <p style="color:rgba(250,248,245,0.65);font-size:0.95rem;line-height:1.8;margin-bottom:32px;">Join 500+ brand builders who start their week with The Editorial.</p>
      <div class="email-strip" style="max-width:400px;margin:0 auto;border-color:rgba(250,248,245,0.3);">
        <input type="email" placeholder="your@email.com" style="background:transparent;color:var(--bg);" aria-label="Email address" />
        <button type="submit" style="background:var(--bg);color:var(--text);">Subscribe</button>
      </div>
    </div>
  </section>

  <!-- Social / Pinterest -->
  <section class="section-sm">
    <div class="container">
      <div class="section-header-center fade-in" style="margin-bottom:32px;">
        <a href="https://pinterest.com/elenatrenchburg" class="label" target="_blank" rel="noopener" style="text-decoration:underline;text-underline-offset:3px;">@elenatrenchburg on Pinterest</a>
      </div>
      <div class="social-grid fade-in fade-in-delay-1">
        {[1,2,3,4,5,6].map(() => (
          <a href="https://pinterest.com/elenatrenchburg" target="_blank" rel="noopener" class="social-tile">
            <img src="/images/instagram-grid.jpg" alt="Pinterest @elenatrenchburg" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
