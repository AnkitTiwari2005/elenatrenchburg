---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Contact — E. Trenchburg Writes" description="Get in touch with E. Trenchburg Writes for brand partnerships, ghostwriting, sponsored content, and workshop inquiries.">
  <Nav />

  <section style="padding-top:calc(var(--nav-h) + 80px);padding-bottom:80px;">
    <div class="container" style="max-width:1000px;margin:0 auto;">

      <div class="section-header-center fade-in" style="margin-bottom:60px;">
        <span class="label" style="margin-bottom:16px;display:block;">Say hello</span>
        <h1 class="display-sm" style="font-style:italic;">let's connect</h1>
        <p style="color:var(--text-muted);margin-top:16px;max-width:520px;margin-left:auto;margin-right:auto;font-size:0.95rem;line-height:1.8;">
          Got a project, partnership idea, or want to talk strategy? We'd love to hear from you. Drop us a note and we'll get back to you within 48 hours.
        </p>
      </div>

      <!-- Testimonials -->
      <div class="grid-3 fade-in" style="margin-bottom:72px;">
        {[
          { quote: 'The E. Trenchburg team completely transformed how our brand communicates. Our engagement tripled.', by: 'TechStartup Client' },
          { quote: "Elena and her team are the real deal — meticulous, strategic, and incredibly talented writers.", by: 'D2C Brand Founder' },
          { quote: 'Working with E. Trenchburg Writes was the best content investment we\'ve made this year.', by: 'SaaS Company CMO' },
        ].map(t => (
          <div style="padding:32px;border:1px solid var(--border);border-radius:var(--radius-lg);">
            <p style="font-family:var(--font-serif);font-style:italic;font-size:1rem;line-height:1.7;margin-bottom:16px;">"{t.quote}"</p>
            <span class="label">{t.by}</span>
          </div>
        ))}
      </div>

      <div class="grid-2 fade-in" style="gap:80px;align-items:start;">

        <!-- Left: Contact info -->
        <div>
          <h2 style="font-family:var(--font-serif);font-style:italic;font-size:1.5rem;margin-bottom:24px;">Ways to Work Together</h2>
          <p style="font-size:0.9rem;color:var(--text-muted);line-height:1.8;margin-bottom:8px;">
            Brand partnerships · Ghostwriting · Sponsored content · Workshops
          </p>
          <p style="font-family:var(--font-mono);font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:32px;">
            Serving clients worldwide / Remote
          </p>

          <div class="divider"></div>

          <h3 style="font-size:0.85rem;font-weight:600;margin-bottom:14px;">Things We Love to Receive</h3>
          <ul class="sparkle-list" style="margin-bottom:32px;">
            <li>Brands who take their voice seriously</li>
            <li>Long-term editorial partnerships</li>
            <li>Speaking & workshop invitations</li>
            <li>Thoughtful project briefs (bonus points)</li>
            <li>Kind notes from happy clients</li>
          </ul>

          <h3 style="font-size:0.85rem;font-weight:600;margin-bottom:14px;">Things That Aren't the Best Fit</h3>
          <ul class="sparkle-list">
            <li>Low-budget / spec work requests</li>
            <li>Projects without clear brand direction</li>
            <li>"We need it by tomorrow" with no brief</li>
          </ul>
        </div>

        <!-- Right: Contact form -->
        <div>
          <form name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" id="contact-form"
            style="display:flex;flex-direction:column;gap:20px;">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" style="display:none;"><input name="bot-field" /></p>

            <div class="form-group">
              <label for="name">Name</label>
              <input id="name" name="name" type="text" class="form-control" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" class="form-control" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label for="company">Company / Brand</label>
              <input id="company" name="company" type="text" class="form-control" placeholder="Company name (optional)" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" class="form-control" placeholder="Tell us about your project..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Send Message</button>
          </form>

          <!-- Success message -->
          <div id="form-success" style="display:none;padding:24px;border:1px solid var(--sage);border-radius:var(--radius-lg);margin-top:20px;text-align:center;">
            <p style="font-family:var(--font-serif);font-style:italic;font-size:1.1rem;color:var(--sage);">Message sent! We'll be in touch within 48 hours. ✦</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    await fetch('/', { method: 'POST', body: data });
    form.style.display = 'none';
    if (success) success.style.display = 'block';
  });
</script>
