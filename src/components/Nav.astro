---
const navItems = [
  {
    label: 'About',
    children: [
      { label: 'Meet Elena', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    label: 'Services',
    children: [
      { label: 'All Services', href: '/services' },
      { label: 'Brand Copywriting', href: '/services/brand-copy' },
      { label: 'Content Strategy', href: '/services/content-strategy' },
      { label: 'Editing & Refinement', href: '/services' },
    ],
  },
  {
    label: 'Explore',
    children: [
      { label: 'Explore All', href: '/explore' },
      { label: 'Blog Posts', href: '/blog' },
      { label: 'Newsletter', href: '/newsletter' },
    ],
  },
  {
    label: 'Resources',
    children: [
      { label: 'Free Downloads', href: '/free-downloads' },
      { label: 'Recommended Tools', href: '/recommended-tools' },
    ],
  },
];
---

<nav class="site-nav" id="site-nav">
  <div class="nav-inner">

    <!-- Left: social icons -->
    <div class="nav-left">
      <a href="https://instagram.com/elenatrenchburg" target="_blank" rel="noopener" class="nav-social-link" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href="https://pinterest.com/elenatrenchburg" target="_blank" rel="noopener" class="nav-social-link" aria-label="Pinterest">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.852 0 1.265.64 1.265 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.562 0-2.387-1.715-4.055-4.163-4.055-2.836 0-4.5 2.126-4.5 4.323 0 .856.33 1.773.741 2.274a.3.3 0 0 1 .069.286c-.076.315-.244.995-.277 1.134-.044.183-.145.221-.335.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.015 0-1.97-.527-2.297-1.148l-.625 2.33c-.226.869-.838 1.956-1.244 2.618.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
        </svg>
      </a>
    </div>

    <!-- Center: wordmark -->
    <a href="/" class="nav-wordmark">E. Trenchburg Writes</a>

    <!-- Right: nav links -->
    <nav class="nav-right" aria-label="Main navigation">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class="nav-item">
            <button class="nav-folder-btn" aria-expanded="false" aria-haspopup="true">
              {item.label}
              <span class="nav-chevron">▾</span>
            </button>
            <div class="nav-dropdown" role="menu">
              {item.children.map((child) => (
                <a href={child.href} role="menuitem">{child.label}</a>
              ))}
            </div>
          </li>
        ))}
        <li class="nav-item">
          <a href="/newsletter" class="nav-link">Newsletter</a>
        </li>
      </ul>
    </nav>

    <!-- Hamburger (mobile) -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</nav>

<!-- Mobile overlay -->
<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <div class="nav-overlay-inner">
    <ul class="mobile-nav-list">
      {navItems.map((item) => (
        <li class="mobile-nav-item">
          <button class="mobile-folder-btn">
            {item.label}
            <span>+</span>
          </button>
          <div class="mobile-folder-content">
            {item.children.map((child) => (
              <a href={child.href}>{child.label}</a>
            ))}
          </div>
        </li>
      ))}
      <li class="mobile-nav-item">
        <a href="/newsletter" class="mobile-nav-link">Newsletter</a>
      </li>
    </ul>
    <div class="mobile-social">
      <a href="https://instagram.com/elenatrenchburg" target="_blank" rel="noopener" style="font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted)">Instagram</a>
      <a href="https://pinterest.com/elenatrenchburg" target="_blank" rel="noopener" style="font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted)">Pinterest</a>
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('site-nav');
  const hamburger = document.getElementById('nav-hamburger');
  const overlay = document.getElementById('nav-overlay');

  // Scroll shadow
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 40);
  });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    overlay?.classList.toggle('open', isOpen);
    overlay?.setAttribute('aria-hidden', String(!isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Mobile accordion
  document.querySelectorAll('.mobile-folder-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const isOpen = content?.classList.toggle('open');
      btn.querySelector('span:last-child')!.textContent = isOpen ? '−' : '+';
    });
  });

  // Scroll fade-in
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), i * 80);
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
