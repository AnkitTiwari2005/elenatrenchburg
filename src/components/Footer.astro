---
const cols = [
  {
    heading: 'About',
    links: [
      { label: 'Meet Elena', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    heading: 'Services',
    links: [
      { label: 'All Services', href: '/services' },
      { label: 'Brand Copywriting', href: '/services/brand-copy' },
      { label: 'Content Strategy', href: '/services/content-strategy' },
      { label: 'Editing & Refinement', href: '/services' },
    ],
  },
  {
    heading: 'Explore',
    links: [
      { label: 'Blog Posts', href: '/blog' },
      { label: 'Newsletter', href: '/newsletter' },
      { label: 'Explore All', href: '/explore' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { label: 'Free Downloads', href: '/free-downloads' },
      { label: 'Recommended Tools', href: '/recommended-tools' },
    ],
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand col -->
      <div class="footer-brand">
        <div class="wordmark">E. Trenchburg Writes</div>
        <p>Words that build authority, earn trust, and leave a mark. For brands that believe in the power of the right word.</p>
        <br />
        <a href="/newsletter" class="btn btn-outline" style="font-size:0.62rem;padding:10px 20px;">Join The Editorial</a>
      </div>

      {cols.map((col) => (
        <div class="footer-col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>© 2024 E. Trenchburg Writes · Ludhiana, India · All rights reserved.</p>
      <div class="social-icons">
        <a href="https://instagram.com/elenatrenchburg" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="https://pinterest.com/elenatrenchburg" target="_blank" rel="noopener" aria-label="Pinterest">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.78 1.18-5 1.18-5s-.3-.6-.3-1.49c0-1.39.81-2.43 1.81-2.43.85 0 1.27.64 1.27 1.41 0 .86-.55 2.14-.83 3.33-.24 1 .5 1.81 1.48 1.81 1.77 0 3.14-1.87 3.14-4.57 0-2.39-1.72-4.06-4.17-4.06-2.84 0-4.5 2.13-4.5 4.33 0 .86.33 1.78.74 2.28a.3.3 0 0 1 .07.29c-.08.32-.24 1-.28 1.14-.04.18-.15.22-.34.13C5.9 14.26 5 12.44 5 11c0-3.15 2.29-6.05 6.61-6.05 3.47 0 6.17 2.47 6.17 5.78 0 3.45-2.17 6.22-5.19 6.22-1.01 0-1.97-.53-2.3-1.15l-.62 2.33c-.23.87-.84 1.96-1.25 2.62.94.29 1.93.45 2.97.45 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
